# BarTV — environment variables
# Copy this file to .env.local and fill in your values.

# ── Supabase (required) ─────────────────────────────────────────────────────
# Find both values in: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Staff access (required) ──────────────────────────────────────────────────
# Passcode for the /dashboard route.  Server-side only — never exposed to the
# browser.  Change this before any live demo.
STAFF_DASHBOARD_PASSCODE=your-passcode-here

# ── Branding (optional) ──────────────────────────────────────────────────────
# Venue name displayed on customer-facing pages.  Defaults to "The Anchor".
NEXT_PUBLIC_VENUE_NAME=Your Bar Name
